    "web:build": "cd web && npm run build"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tauri-apps/cli": "^2.10.1",
    "@tsconfig/svelte": "^5.0.8",
    "svelte": "^5.55.5",
    "svelte-check": "^4.4.8",
    "tslib": "^2.8.1",
    "typescript": "^6.0.2",
    "vite": "^8.0.10"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-shell": "^2.3.5"
  }
}
